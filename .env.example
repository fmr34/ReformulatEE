# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Anthropic API
# - Geração de candidatos no HF Space (obrigatório quando SPACE_ID presente)
# - Fallback de tratabilidade quando o classificador local não está treinado
# - Fallback de tradução quando transformers não está instalado
ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace Hub
# - Logging de perguntas no HF Dataset (cross-session, multi-usuário)
# - Histórico persistente entre reinícios do Space
# - Token com permissão de escrita no repositório fmr34/reformulatee-logs
HF_TOKEN=hf_...
HF_USERNAME=seu_username

# Semantic Scholar API key (opcional — sem key funciona, mas com key tem rate limit maior)
# https://www.semanticscholar.org/product/api
S2_API_KEY=

# Backend de inferência
# ollama       = modelo fine-tuned local via Ollama (recomendado para uso local, custo zero)
# claude       = Claude API (usado automaticamente no HF Space quando SPACE_ID presente)
# hf_inference = HF Inference API serverless (modelos públicos, gratuito)
# gguf         = modelo GGUF local via llama-cpp-python
INFERENCE_BACKEND=ollama

# Ollama (uso local com modelo fine-tuned)
OLLAMA_MODEL=reformulatee
OLLAMA_BASE_URL=http://localhost:11434

# HF Inference API (fallback ou uso explícito)
HF_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Corpus local — caminho onde o corpus de papers está salvo
CORPUS_DIR=data/corpus

# Parâmetros da função de recompensa (Patch C.5)
BETA1='0.05'
BETA2='0.05'
BETA3='0.9'
ALPHA=0.5
EPSILON='0.05'
DELTA_INTRA=0.05
BELL_CENTER='0.5'
BELL_WIDTH='0.25'
