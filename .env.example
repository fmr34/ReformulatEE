# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Anthropic API — usado no stub de Tratabilidade (Fase 0)
ANTHROPIC_API_KEY=sk-ant-...

# Semantic Scholar API key (opcional — sem key funciona, mas com key tem rate limit maior)
# https://www.semanticscholar.org/product/api
S2_API_KEY=

# Modelo fine-tunado via DPO (Onda 4) — publicado no HF Hub
# Substitua pelo seu repo após treinar: python -m src.rl.inference para testar
# Para HF Spaces (serverless, gratuito): usar modelo base
HF_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# Para uso local com modelo fine-tuned (requer download ~3GB):
# HF_MODEL=fmr34/reformulatee-reformulator-merged
INFERENCE_BACKEND=hf_inference   # hf_inference | gguf | claude | local

# HuggingFace Hub
HF_TOKEN=hf_...
HF_USERNAME=seu_username

# Corpus local — caminho onde o arXiv subset será salvo
CORPUS_DIR=./data/corpus

# Parâmetros da função de recompensa (valores iniciais do patch C.5)
BETA1=0.33
BETA2=0.33
BETA3=0.34
ALPHA=0.5
EPSILON=0.10
DELTA_INTRA=0.05
